NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Harold AI via n8n
N8N_HAROLD_WEBHOOK=

# Agent Inbox via n8n. The outbound workflow receives agent.email.send events.
N8N_AGENT_EMAIL_WEBHOOK=
# Use the same secret as a Bearer token when n8n POSTs inbound email events to
# /api/integrations/agent-email.
AGENT_EMAIL_WEBHOOK_SECRET=

# External catalog sync for products, rate plans, and agent companies.
# POST /api/integrations/catalog/products
# POST /api/integrations/catalog/rates
# POST /api/integrations/catalog/agencies
# POST /api/integrations/bookings/expire-holds
INTEGRATION_API_SECRET=

# Live availability source (GET startDate/endDate -> per-day unit counts).
AVAILABILITY_API_URL=https://swagoldendusk.xyz/api/availability

# GoldenDusk / SWAIBMS read API (accommodation + activities catalog import).
GOLDEN_DUSK_API_BASE_URL=https://swagoldendusk.xyz/api
# Agent portal auth uses the same base URL (/api/agent/auth/*, /api/agent/bookings/quote).
# Optional override when importing rate sheets (defaults to current year).
GOLDEN_DUSK_RATES_YEAR=2026

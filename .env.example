NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Harold AI via n8n
N8N_HAROLD_WEBHOOK=

# Agent Inbox via n8n. The outbound workflow receives agent.email.send events.
N8N_AGENT_EMAIL_WEBHOOK=
# Use the same secret as a Bearer token when n8n POSTs inbound email events to
# /api/integrations/agent-email.
AGENT_EMAIL_WEBHOOK_SECRET=
